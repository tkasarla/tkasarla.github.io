  "devDependencies": {
    "prettier": "^3.8.3",
    "postcss-scss": "^4.0.9",
    "stylelint": "^16.26.1"
  },
  "scripts": {
    "test": "npm run lint:scss",
    "lint:scss": "stylelint '_sass/custom/**/*.scss'",
