{
  "name": "tkasarla.github.io",
  "version": "0.3.3",
  "description": "Personal website for Tejaswi Kasarla",
  "repository": "tkasarla/tkasarla.github.io",
  "license": "MIT",
  "bugs": "https://github.com/tkasarla/tkasarla.github.io/issues",
  "devDependencies": {
    "prettier": "^3.8.3",
    "stylelint": "^16.26.1",
    "stylelint-config-primer": "^11.1.1",
    "stylelint-config-prettier-scss": "1.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-prettier": "^5.0.3"
  },
  "scripts": {
    "test": "npm run lint:scss",
    "lint:scss": "stylelint '**/*.scss'",
    "build": "bundle exec jekyll build",
    "serve": "bundle exec jekyll serve -H 0.0.0.0 -t",
    "format": "prettier --write '**/*.{scss,js,json}'",
    "stylelint-check": "stylelint-config-prettier-check"
  }
}
